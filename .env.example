# Anthropic-nyckel för kvittotolkningen. Läses ENBART från miljön —
# aldrig argv, aldrig incheckad fil. Utan nyckel kör skivan automatiskt
# den deterministiska fallback-tolkningen (samma schema, mock-läge).
ANTHROPIC_API_KEY=

# Valfritt: modell för tolkningen (default claude-opus-4-8)
# GRUNDBOK_MODEL=claude-opus-4-8

# Valfritt: tvinga fallback-läget även med nyckel satt (demo/test)
# GRUNDBOK_FORCE_FALLBACK=1

# Langfuse-observability (valfritt). Utan nycklar: tracing är en no-op —
# observability får aldrig fälla ett jobb. All input/output maskeras
# (allowlist i src/lib/observability/mask.ts) innan export: underlagstext,
# motpartsnamn och belopp lämnar aldrig processen.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# EU-molnet: https://cloud.langfuse.com — US: https://us.cloud.langfuse.com
LANGFUSE_BASE_URL=https://cloud.langfuse.com
# Valfritt: miljöstämpel på traces (default "default")
# LANGFUSE_TRACING_ENVIRONMENT=development
