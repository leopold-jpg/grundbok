# Anthropic-nyckel för kvittotolkningen. Läses ENBART från miljön —
# aldrig argv, aldrig incheckad fil. Utan nyckel kör skivan automatiskt
# den deterministiska fallback-tolkningen (samma schema, mock-läge).
ANTHROPIC_API_KEY=

# Valfritt: modell för tolkningen (default claude-opus-4-8)
# GRUNDBOK_MODEL=claude-opus-4-8

# Valfritt: tvinga fallback-läget även med nyckel satt (demo/test)
# GRUNDBOK_FORCE_FALLBACK=1
